# --- Postgres (app read-model + ledger) ---
DATABASE_URL=postgresql+psycopg://perishable:perishable@localhost:5432/perishable

# --- Temporal ---
# Local dev server / compose cluster:
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=perishables-tq

# Temporal Cloud (API-key auth) — set TEMPORAL_API_KEY to switch over.
# TEMPORAL_ADDRESS=<namespace>.<account>.tmprl.cloud:7233
# TEMPORAL_NAMESPACE=<namespace>.<account-id>
# TEMPORAL_API_KEY=<temporal-cloud-api-key>

# --- Inventory Item Details API (Bolt Gateway) ---
# INVENTORY_SOURCE=live -> real on-hand + listing price; =stub -> synthetic curve.
INVENTORY_SOURCE=stub
# OUTWARDED sell-through window ladder (hours, widest first). Must stay UNDER the
# gateway's 48h (2-day) hard cap — 47 leaves margin for clock skew. First window
# that returns before timing out wins.
INVENTORY_SELLTHROUGH_WINDOWS_H=47,36,24
BOLT_BASE_URL=https://bolt.jumbotail.com
BOLT_USER_ID=<caller-email>
BOLT_ORG_ID=<caller-orgprof-id>
BOLT_AUTH_TOKEN=Bearer <gateway-jwt>

# Per-JPIN OUTWARDED sell-through scan timeout (seconds). The endpoint is slow /
# un-indexed for high-volume sellers, so this is only a partial mitigation — the
# real fix is a time-indexed OUTWARDED query or POS feed from SCM. Sim mode
# (below) sidesteps it entirely by driving sell-through from the UI.
BOLT_SELLTHROUGH_TIMEOUT_S=180

# --- Dead-stock multi-day clearance (separate workflow + UI page) ---
# Dead-stock detection reuses posgateway (same source as j24-pulse). Copy these
# from the j24-pulse .env. The endpoint is slow (minutes) — DEADSTOCK_TIMEOUT_S
# bounds each call.
POSGATEWAY_BASE_URL=http://posgateway.prod.jumbotail.com
POSGATEWAY_TOKEN=
DEADSTOCK_TIMEOUT_S=180
# SKU master (shelf life by JPIN) — a parquet published to S3 (preferred) or a
# local file for tests. Needs AWS creds + region for the S3 read (dead stock can
# be any SKU, so shelf life comes from here, not the 9-item leafy catalogue).
SKU_MASTER_S3_URI=
# e.g. s3://j24-master/sku-master/latest/sku_master.parquet
SKU_MASTER_PATH=
# AWS_ACCESS_KEY_ID= / AWS_SECRET_ACCESS_KEY= / AWS_DEFAULT_REGION=ap-southeast-1

# --- v3: projection + shared read-model ---
# Projection mode: v3 = profile-aware pace (uses the hourly demand shape),
# v2 = flat rate * remaining_h (legacy). Snapshotted at run start.
PROJECTION_MODE=v3
# Read sell-through from the shared facility snapshot (needs start_poller.py
# running) vs a direct per-batch Bolt read. false = direct (simplest for tests).
READ_FROM_SNAPSHOT=false
# Intraday-profile artifact (parquet/csv). It is produced by a SEPARATE hourly-
# forecast workflow (NOT in this repo) that publishes to S3 — we only read it.
# Prefer the S3 URI; it may template {store} and {date} (IST, resolved at read
# time) and is cached locally, busted by the object's ETag. If unset/unreadable,
# adapters/profile.py falls back to a synthetic evening-peaked curve, so v3 is
# testable with NO artifact. INTRADAY_PROFILE_PATH is a local override for
# tests/offline; the S3 URI takes precedence when both are set.
INTRADAY_PROFILE_S3_URI=
# e.g. s3://j24-forecast/intraday-shares/{store}/{date}/intraday_shares.parquet
INTRADAY_PROFILE_PATH=
# AWS_REGION=ap-south-1     # region for the S3 reads (default ap-south-1)

# --- Local end-to-end testing against the stateful mock gateway ---
# Run: uvicorn tools.mock_bolt:app --port 9099
# Then set (overrides the Bolt section above):
#   INVENTORY_SOURCE=live
#   BOLT_BASE_URL=http://localhost:9099
#   BOLT_AUTH_TOKEN=mock
# MOCK_SPEED compresses the selling day (match --speed on starter.py).
MOCK_SPEED=1800
