# --- Postgres (app read-model + ledger) ---
DATABASE_URL=postgresql+psycopg://perishable:perishable@localhost:5432/perishable

# --- Temporal ---
# Local dev server / compose cluster:
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=perishables-tq

# Temporal Cloud (API-key auth) — set TEMPORAL_API_KEY to switch over.
# TEMPORAL_ADDRESS=<namespace>.<account>.tmprl.cloud:7233
# TEMPORAL_NAMESPACE=<namespace>.<account-id>
# TEMPORAL_API_KEY=<temporal-cloud-api-key>
